# iFinD QuantAPI Credentials
IFIND_USERNAME=your_ifind_username_here
IFIND_PASSWORD=your_ifind_password_here

# PostgreSQL Credentials (Optional, defaults generally work for local testing)
PG_DBNAME=quant_db
PG_USER=postgres
PG_PASSWORD=your_pg_password_here
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME_TEST=quant_db_test


# SimNow CTP Credentials
SIMNOW_INVESTOR_ID=your_simnow_investor_id_here
SIMNOW_PASSWORD=your_simnow_password_here
SIMNOW_BROKER_ID=9999

# CTP 客户端认证 (现代柜台必须，SimNow 测试环境固定值)
SIMNOW_APP_ID=simnow_client_test
SIMNOW_AUTH_CODE=0000000000000000

# ── SimNow 前置地址 ──────────────────────────────────────────
# 第一套环境（标准环境）：交易日 08:55-15:30 / 夜盘 20:55-23:00
SIMNOW_TRADE_FRONT=tcp://180.168.146.187:10130
SIMNOW_MD_FRONT=tcp://180.168.146.187:10131

# 第二套环境（7x24环境）：交易日 16:00-次日09:00 / 非交易日 16:00-次日12:00
# 切换时将上方两行注释掉，启用下方两行
# SIMNOW_TRADE_FRONT=tcp://182.254.243.31:40001
# SIMNOW_MD_FRONT=tcp://182.254.243.31:40011
